generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                  String               @id @default(uuid())
  name                String               @unique
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  logoUrl             String?
  agents              Agent[]
  branches            Branch[]
  commands            Command[]
  companyPermissions  CompanyPermission[]
  customerMemberships CustomerMembership[]
  devices             Device[]
  membershipSales     MembershipSale[]
  partners            Partner[]
  plan                Plan[]
  role                Role[]
  users               User[]
  userRoles           UserRole[]
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String
  fullName        String
  isActive        Boolean          @default(true)
  companyId       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  branchId        String
  isOwner         Boolean          @default(false)
  membershipSales MembershipSale[]
  branch          Branch           @relation(fields: [branchId], references: [id])
  company         Company          @relation(fields: [companyId], references: [id])
  roles           UserRole[]

  @@index([companyId])
  @@index([branchId])
}

model Role {
  id          String           @id @default(uuid())
  name        String
  scope       RoleScope
  companyId   String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  company     Company?         @relation(fields: [companyId], references: [id])
  permissions RolePermission[]
  users       UserRole[]

  @@unique([name, scope, companyId])
}

model Permission {
  id                 String              @id @default(uuid())
  code               String              @unique
  description        String?
  scope              RoleScope
  isActive           Boolean             @default(true)
  companyPermissions CompanyPermission[]
  roles              RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
}

model CompanyPermission {
  id           String     @id @default(uuid())
  companyId    String
  permissionId String
  createdAt    DateTime   @default(now())
  company      Company    @relation(fields: [companyId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([companyId, permissionId])
  @@index([companyId])
  @@index([permissionId])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, roleId, companyId])
}

model Branch {
  id              String               @id @default(uuid())
  name            String
  companyId       String
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  agents          Agent[]              @relation("BranchAgents")
  company         Company              @relation(fields: [companyId], references: [id])
  commands        Command[]
  memberships     CustomerMembership[]
  devices         Device[]
  membershipSales MembershipSale[]
  users           User[]

  @@unique([name, companyId])
}

/// ////////////
/// ///////////
model Partner {
  id              String              @id @default(uuid())
  companyId       String
  type            PartnerType
  name            String
  document        String?
  phone           String?
  email           String?
  address         String?
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  imageUrl        String?
  membership      CustomerMembership?
  membershipSales MembershipSale[]
  company         Company             @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model Device {
  id               String       @id @default(uuid())
  name             String
  ip               String
  port             Int?
  username         String?
  password         String?
  deviceType       DeviceType
  brand            String
  isActive         Boolean      @default(true)
  companyId        String
  branchId         String
  agentId          String?
  lastSeenAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  lastConnectionAt DateTime?
  status           DeviceStatus @default(DISCONNECTED)
  agent            Agent?       @relation(fields: [agentId], references: [id])
  branch           Branch       @relation(fields: [branchId], references: [id])
  company          Company      @relation(fields: [companyId], references: [id])

  @@unique([branchId, ip])
  @@index([companyId])
  @@index([branchId])
}

/// //////////////
/// ///////////////
model Plan {
  id              String           @id @default(uuid())
  name            String
  description     String?
  price           Decimal
  durationDays    Int
  isActive        Boolean          @default(true)
  companyId       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  membershipSales MembershipSale[]
  company         Company          @relation(fields: [companyId], references: [id])

  @@unique([name, companyId])
}

model MembershipSale {
  id        String           @id @default(uuid())
  partnerId String
  planId    String
  companyId String
  startDate DateTime
  endDate   DateTime
  status    MembershipStatus @default(ACTIVE)
  price     Decimal          @db.Decimal(10, 2)
  createdAt DateTime         @default(now())
  saleDate  DateTime         @default(now())
  userId    String?
  branchId  String?
  commands  Command[]
  branch    Branch?          @relation(fields: [branchId], references: [id])
  company   Company          @relation(fields: [companyId], references: [id])
  partner   Partner          @relation(fields: [partnerId], references: [id])
  plan      Plan             @relation(fields: [planId], references: [id])
  user      User?            @relation(fields: [userId], references: [id])

  @@index([partnerId])
  @@index([endDate])
}

model CustomerMembership {
  id                String           @id @default(uuid())
  customerId        String           @unique
  companyId         String
  startDate         DateTime
  endDate           DateTime
  status            MembershipStatus @default(ACTIVE)
  hikvisionUserId   String?
  deletedFromDevice Boolean          @default(false)
  lastSyncAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  branchId          String
  branch            Branch           @relation(fields: [branchId], references: [id])
  company           Company          @relation(fields: [companyId], references: [id])
  customer          Partner          @relation(fields: [customerId], references: [id])

  @@index([endDate])
}

/// //////
/// //
model Agent {
  id         String    @id @default(uuid())
  name       String
  agentKey   String    @unique
  companyId  String
  branchId   String
  isActive   Boolean   @default(true)
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
  publicIp   String?
  branch     Branch    @relation("BranchAgents", fields: [branchId], references: [id])
  company    Company   @relation(fields: [companyId], references: [id])
  devices    Device[]

  @@unique([branchId, name])
  @@index([companyId])
  @@index([branchId])
  @@index([publicIp])
}

model Command {
  id               String          @id @default(uuid())
  payload          Json
  companyId        String
  branchId         String
  createdAt        DateTime        @default(now())
  executedAt       DateTime?
  error            String?
  attempts         Int             @default(0)
  type             CommandType
  status           CommandStatus   @default(PENDING)
  membershipSaleId String?
  branch           Branch          @relation(fields: [branchId], references: [id])
  company          Company         @relation(fields: [companyId], references: [id])
  membershipSale   MembershipSale? @relation(fields: [membershipSaleId], references: [id])

  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([branchId, status])
  @@index([membershipSaleId])
}

enum RoleScope {
  SYSTEM
  TENANT
}

enum PartnerType {
  CUSTOMER
  SUPPLIER
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  ANULLED
}

enum DeviceType {
  ACCESS_CONTROL
  CAMERA
  BIOMETRIC
}

enum DeviceStatus {
  CONNECTED
  DISCONNECTED
}

enum CommandStatus {
  PENDING
  PROCESSING
  DONE
  ERROR
}

enum CommandType {
  SYNC_MEMBERSHIP
  DELETE_USER
  SYNC_FACE
  SYNC_USER_FULL
}
